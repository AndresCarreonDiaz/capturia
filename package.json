    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "node-addon-api": "^8.9.0",
    "node-gyp": "^12.4.0",
