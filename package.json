  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.71",
    "@ai-sdk/openai": "^3.0.63",
    "@anthropic-ai/sdk": "^0.57.0",
    "@copilotkit/a2ui-renderer": "^1.57.1",
    "@copilotkit/react-core": "^1.57.1",
