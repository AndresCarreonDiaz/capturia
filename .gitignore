# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/.spike-out/

# native addon build output (node-gyp) and assembled bundles
native/*/build/
native/*/dist/

# next.js
/.next/
/out/

# electron build artifacts (compiled main-process libs + export hold dir)
/electron/gen/
/.electron-export-hold/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pdfjs worker is vendored into public/ by scripts/copy-pdf-worker.mjs (postinstall)
/public/pdf.worker.min.mjs

# Claude Code local runtime (scheduled-task locks, local settings)
/.claude/

# packaged desktop app output
/dist-app/
/build/icon.iconset/

# whisper packaging stage (self-contained copy for extraResources)
/.whisper-stage/

# native spike binaries (built ad hoc via swiftc)
/native/capturia-speech/speech-spike

# speech helper binary: arch-specific, built by scripts/build-speech-helper.mjs
# (pack:mac and smoke:speech build it on demand; never commit it)
/native/capturia-speech/capturia-speech
